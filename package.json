{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "@orionhosting/cli",
    "version": "0.4.5",
    "description": "Deploy your projects from the terminal",
    "keywords": [
        "cli",
        "host",
        "hosting",
        "octara",
        "orion",
        "voctal"
    ],
    "homepage": "https://github.com/orionhosting/cli",
    "bugs": {
        "url": "https://github.com/orionhosting/cli/issues"
    },
    "license": "GPL-3.0-only",
    "author": "orionhosting",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/orionhosting/cli.git"
    },
    "bin": {
        "orion": "dist/index.mjs"
    },
    "files": [
        "configuration_schema.json",
        "dist"
    ],
    "type": "module",
    "scripts": {
        "build": "npm run build:schema && tsdown",
        "build:schema": "tsx scripts/json-schema",
        "lint": "tsc --noEmit && oxlint && oxfmt --check",
        "fmt": "oxfmt"
    },
    "dependencies": {
        "@inquirer/confirm": "^6.0.11",
        "@inquirer/input": "^5.0.10",
        "@inquirer/password": "^5.0.10",
        "@inquirer/select": "^5.1.2",
        "@voctal/pelican": "^0.7.6",
        "archiver": "^7.0.1",
        "boxen": "^8.0.1",
        "chalk": "^5.3.0",
        "commander": "^12.1.0",
        "dotenv": "^17.4.1",
        "env-paths": "^4.0.0",
        "figures": "^6.1.0",
        "ink": "^6.8.0",
        "minimatch": "^10.2.5",
        "open": "^11.0.0",
        "ora": "^8.0.1",
        "react": "^19.2.4",
        "update-notifier": "^7.3.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/archiver": "^6.0.2",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "@types/update-notifier": "^6.0.8",
        "oxfmt": "^0.42.0",
        "oxlint": "^1.57.0",
        "tsdown": "^0.21.7",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    },
    "engines": {
        "node": ">=23"
    }
}
